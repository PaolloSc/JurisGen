# ─── Modo de Autenticação Claude ───────────────────────
# "cli" = Via Claude Code CLI (usa tokens da assinatura Pro/Max)
CLAUDE_AUTH_MODE=cli

# ─── Microsoft Entra ID (SharePoint) ──────────────────
MS_TENANT_ID=seu-tenant-id
MS_CLIENT_ID=seu-client-id
MS_CLIENT_SECRET=seu-client-secret
SHAREPOINT_SITE_ID=seusite.sharepoint.com,site-guid,web-guid
SHAREPOINT_DRIVE_ID=drive-id-aqui

# ─── App Config ────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001
