# ─── Modo de Autenticação Claude ───────────────────────
# "cli" = Via Claude Code CLI (usa tokens da assinatura Pro/Max)
CLAUDE_AUTH_MODE=cli

# ─── Jurema 7B — Provedor ──────────────────────────────
# "ollama" = Modelo local via Ollama (recomendado para Cloudflare/prod)
# "hf"     = HuggingFace Inference API (requer HF_API_KEY)
# vazio    = Jurema desabilitada
JUREMA_PROVIDER=ollama

# Ollama: URL e nome do modelo Jurema (quando JUREMA_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434
JUREMA_OLLAMA_MODEL=jurema

# HuggingFace: chave de API (quando JUREMA_PROVIDER=hf)
HF_API_KEY=

# ─── Jurema Retry / Circuit Breaker ───────────────────
JUREMA_MAX_RETRIES=3
JUREMA_COOLDOWN_SECONDS=120
JUREMA_REQUEST_TIMEOUT=45

# ─── Microsoft Entra ID (SharePoint) ──────────────────
MS_TENANT_ID=seu-tenant-id
MS_CLIENT_ID=seu-client-id
MS_CLIENT_SECRET=seu-client-secret
SHAREPOINT_SITE_ID=seusite.sharepoint.com,site-guid,web-guid
SHAREPOINT_DRIVE_ID=drive-id-aqui

# ─── SharePoint Auto-Sync ──────────────────────────────
# Ativa download automático da biblioteca ao iniciar o servidor (padrão: true)
SHAREPOINT_AUTO_SYNC=true
# Intervalo de re-sincronização em horas (padrão: 1)
SHAREPOINT_SYNC_INTERVAL_HOURS=1
# Extensões de arquivo para baixar (padrão: pdf,docx,doc,txt)
SHAREPOINT_EXTENSIONS=pdf,docx,doc,txt
# Diretório local para cache dos arquivos (padrão: ./sharepoint_files)
# SHAREPOINT_FILES_DIR=/data/sharepoint_files

# ─── Vector Store (RAG) ────────────────────────────────
# Diretório do banco vetorial ChromaDB (padrão: ./chroma_db)
# CHROMA_PATH=/data/chroma_db
# Modelo de embeddings sentence-transformers (padrão: multilingual)
# EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

# ─── App Config ────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001

# ─── Cloudflare Tunnel ────────────────────────────────
# Para Quick Tunnel via Docker Compose (TUNNEL_TOKEN obtido em Cloudflare Zero Trust)
# TUNNEL_TOKEN=eyJ...
# CORS para domínios personalizados (regex, separado por |)
# CORS_REGEX=https://.*\.meudominio\.com
